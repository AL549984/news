TRIGGER_PROJECT_REF=proj_hfkmpivzdhbvbvfffcsg
TRIGGER_SECRET_KEY=tr_dev_or_prod_xxx
# Optional for local/CI deploy auth. Export it in your shell; the CLI reads it before .env is loaded.
# TRIGGER_ACCESS_TOKEN=tr_pat_xxx

# GitHub publishing. Use a fine-grained token with Contents read/write on AL549984/news.
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPOSITORY=AL549984/news
GITHUB_BRANCH=main
GITHUB_ARTICLES_PATH=articles.js

# Optional sync inputs. Add the real Python sync script to scripts/ or point these at bundled paths.
TENCENT_RESEARCH_SYNC_SCRIPT=./scripts/sync_tencent_research_wechat_to_feishu_wiki.py
TENCENT_RESEARCH_EXPORT_SCRIPT=./scripts/export_tencent_research_site_articles.py
TENCENT_RESEARCH_STATE_PATH=./data/tencent_research_wechat_wiki/state.json
TENCENT_RESEARCH_ARTICLES_PATH=./articles.js
TENCENT_RESEARCH_CRON=0 19 * * *
TENCENT_RESEARCH_POLL_CRON=*/5 * * * *
TENCENT_RESEARCH_TIMEZONE=Asia/Shanghai

# Optional production mode: let Trigger orchestrate the existing Hermes server sync over SSH.
# Store password/private key as Secret values in Trigger.dev, never in this file.
HERMES_SSH_HOST=124.221.3.41
HERMES_SSH_USER=ubuntu
HERMES_SSH_PORT=22
# HERMES_SSH_PASSWORD=...
# HERMES_SSH_PRIVATE_KEY=...
HERMES_SSH_TIMEOUT_MS=1200000
HERMES_REMOTE_COMMAND=cd /home/ubuntu/.hermes/profiles/news && bash scripts/sync_tencent_research_wechat_to_feishu_wiki_daily.sh
HERMES_POLL_TIMEOUT_MS=600000
HERMES_REMOTE_POLL_COMMAND=cd /home/ubuntu/.hermes/profiles/news && /usr/bin/python3 scripts/tencent_research_realtime_watcher.py --once --quiet-noop --deploy-timeout 600 --deploy-cmd /usr/bin/python3 scripts/push_tencent_research_site_to_github.py
